"use client";

// This page has been updated to wrap useSearchParams in a Suspense boundary
// as required by Next.js 15+ to ensure proper static generation
// See: https://nextjs.org/docs/messages/prerender-error
import { useState, useEffect, Suspense } from "react";
import { useSearchParams, useRouter } from "next/navigation";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { Alert, AlertDescription } from "@/components/ui/alert";
import { CheckCircle, ChevronLeft, MoveRight, Mail, User, CreditCard, Shield } from "lucide-react";
import Image from "next/image";
import { TawkToChat } from "@/components/tawk-to-chat";
import { submitToGoogleScript, submitViaIframe } from "@/lib/google-script";

// Client Component that uses search params
function SubscribePageContent() {
  const router = useRouter();
  const searchParams = useSearchParams();
  const plan = searchParams.get("plan") || "12 Months";
  const successParam = searchParams.get("success");
  
  const [formState, setFormState] = useState({
    name: "",
    email: "",
    success: successParam === "true",
    error: ""
  });

  const [submitting, setSubmitting] = useState(false);
  const [isChatLoading, setIsChatLoading] = useState(false);

  // Effect to handle opening chat when submission is successful
  useEffect(() => {
    if (formState.success) {
      // Delay opening the chat to ensure it loads after form submission
      const timer = setTimeout(() => {
        setIsChatLoading(true);
        
        // Set visitor information for Tawk.to chat if available
        if (window.Tawk_API) {
          window.Tawk_API.visitor = {
            name: formState.name,
            email: formState.email
          };
          
          // Check if the API is already loaded and maximize it
          if (typeof window.Tawk_API.maximize === 'function') {
            window.Tawk_API.maximize();
            // Set loading to false after a bit to allow for animation
            setTimeout(() => {
              setIsChatLoading(false);
            }, 1500);
          }
        } else {
          // Set loading to false after a timeout if API isn't available
          setTimeout(() => {
            setIsChatLoading(false);
          }, 3000);
        }
      }, 2000);
      
      return () => clearTimeout(timer);
    }
  }, [formState.success, formState.name, formState.email]);

  const goBack = () => {
    router.push("/#pricing");
  };

  const handleSubmit = async (e: React.FormEvent<HTMLFormElement>) => {
    e.preventDefault(); // We'll handle the submission manually
    setSubmitting(true);
    
    try {
      const form = e.currentTarget;
      const formData = new FormData(form);
      
      // Add plan information to the form data
      formData.append('plan', plan);
      formData.append('timestamp', new Date().toISOString());
      
      // Log form data for debugging
      console.log('Form data being submitted:', Object.fromEntries(formData.entries()));
      
      // Submit to Google Apps Script - using our utility function
      const googleScriptUrl = 'https://script.google.com/macros/s/AKfycbz_t77GINGIcOOBo0UnJYxv3E_VKQZd6hq85fpnFazUqVxjFqtlmZ0qmdbKEk2KqctW6g/exec';
      
      // Try primary submission method first
      const googleScriptSuccess = await submitToGoogleScript(googleScriptUrl, formData);
      
      if (!googleScriptSuccess) {
        // If fetch method fails, try iframe submission as fallback
        console.log('Primary submission method failed, trying iframe fallback...');
        await submitViaIframe(googleScriptUrl, formData);
      }
      
      // As a tertiary fallback, also try Netlify form submission
      try {
        // Ensure the form-name field is set for Netlify
        formData.set('form-name', 'subscription');
        
        // Submit to Netlify's form handler
        await fetch('/', {
          method: 'POST',
          headers: { 
            'Content-Type': 'application/x-www-form-urlencoded',
          },
          body: new URLSearchParams(formData as any).toString()
        });
      } catch (netlifyError) {
        // Just log the error, we don't need to take action if Netlify fails
        console.warn('Netlify form submission failed (tertiary):', netlifyError);
      }
      
      // If we've made it this far, consider the form submitted successfully
      setFormState(prev => ({
        ...prev,
        success: true
      }));
      
      // Begin the sequence to open chat
      if (window.Tawk_API) {
        window.Tawk_API.visitor = {
          name: formState.name || '',
          email: formState.email || ''
        };
      }
      
      // Add a slight delay before triggering the chat to open
      setTimeout(() => {
        setIsChatLoading(true);
      }, 1500);
      
      setSubmitting(false);
    } catch (error) {
      console.error('Error submitting form:', error);
      
      // Set a more helpful error message
      let errorMessage = "There was an error processing your subscription. Please try again.";
      
      if (error instanceof Error) {
        if (error.message.includes('network') || error.message.includes('failed to fetch')) {
          errorMessage = "Network error. Please check your internet connection and try again.";
        }
      }
      
      setFormState(prev => ({
        ...prev,
        error: errorMessage
      }));
      
      // Open chat support even on error to help the user
      if (window.Tawk_API) {
        window.Tawk_API.visitor = {
          name: formState.name || '',
          email: formState.email || ''
        };
        
        // Try to maximize the chat window
        try {
          if (typeof window.Tawk_API.maximize === 'function') {
            window.Tawk_API.maximize();
          }
        } catch (e) {
          console.error('Error opening chat on form error:', e);
        }
      }
      
      setSubmitting(false);
    }
  };

  return (
    <div className="min-h-screen bg-gradient-to-b from-background to-secondary/10 py-12 px-4">
      <div className="container max-w-4xl mx-auto">
        <Button 
          variant="outline" 
          className="mb-6 flex items-center gap-2 rounded-lg border border-primary/20 hover:bg-primary/5 hover:border-primary/40 hover:text-primary transition-all duration-200" 
          onClick={goBack}
        >
          <ChevronLeft className="h-4 w-4 text-primary" />
          <span>Back to Pricing</span>
        </Button>
        
        <Card className="w-full rounded-xl shadow-xl overflow-hidden border-primary/10">
          <div className="relative">
            <div className="absolute inset-0 bg-primary/5 z-0"></div>
            <CardHeader className="text-center relative z-10 pt-8 pb-6">
              <div className="mb-4 inline-flex mx-auto p-4 rounded-full bg-primary/10">
                <CreditCard className="h-8 w-8 text-primary" />
              </div>
              <CardTitle className="text-2xl sm:text-3xl font-bold text-foreground bg-clip-text text-transparent bg-gradient-to-r from-primary to-primary/80">
                Complete Your Subscription
              </CardTitle>
              <CardDescription className="text-sm sm:text-base mt-2 text-muted-foreground">
                Subscribe to our <span className="font-semibold text-primary">{plan}</span> plan to enjoy premium IPTV streaming
              </CardDescription>
            </CardHeader>
          </div>
          
          <CardContent>
            {!formState.success ? (
              <form 
                onSubmit={handleSubmit} 
                className="space-y-6"
                method="POST"
                name="subscription"
                id="subscription-form"
                data-netlify="true"
                netlify-honeypot="bot-field"
              >
                {/* Hidden fields for form processing */}
                <input type="hidden" name="form-name" value="subscription" />
                <input type="hidden" name="plan" value={plan} />
                <input type="hidden" name="timestamp" value={new Date().toISOString()} />
                
                {/* Honeypot field for spam protection */}
                <div className="hidden">
                  <label>Don't fill this out if you're human: <input name="bot-field" /></label>
                </div>
                
                <div className="space-y-6">
                  <div className="space-y-2">
                    <Label htmlFor="name" className="text-sm sm:text-base font-medium flex items-center gap-2">
                      <User className="h-4 w-4 text-primary" />
                      Your Name
                    </Label>
                    <div className="relative">
                      <Input 
                        id="name" 
                        name="name" 
                        placeholder="Enter your full name" 
                        value={formState.name}
                        onChange={(e) => setFormState(prev => ({ ...prev, name: e.target.value }))}
                        className="w-full pl-10 transition-shadow focus:shadow-md border-primary/20 focus:border-primary"
                        data-sheet-column="Name"
                        required
                      />
                      <User className="h-4 w-4 text-muted-foreground absolute left-3 top-1/2 transform -translate-y-1/2" />
                    </div>
                  </div>
                  
                  <div className="space-y-2">
                    <Label htmlFor="email" className="text-sm sm:text-base font-medium flex items-center gap-2">
                      <Mail className="h-4 w-4 text-primary" />
                      Email Address
                    </Label>
                    <div className="relative">
                      <Input 
                        id="email" 
                        name="email" 
                        type="email"
                        placeholder="Enter your email address" 
                        value={formState.email}
                        onChange={(e) => setFormState(prev => ({ ...prev, email: e.target.value }))}
                        className="w-full pl-10 transition-shadow focus:shadow-md border-primary/20 focus:border-primary"
                        data-sheet-column="Email"
                        required
                      />
                      <Mail className="h-4 w-4 text-muted-foreground absolute left-3 top-1/2 transform -translate-y-1/2" />
                    </div>
                  </div>
                  
                  <div className="mt-6">
                    <div className="bg-gradient-to-r from-secondary/30 to-secondary/10 p-5 sm:p-6 rounded-xl shadow-inner border border-primary/10">
                      <div className="flex items-center gap-3 mb-4">
                        <div className="bg-primary/10 p-2 rounded-full">
                          <CreditCard className="h-5 w-5 text-primary" />
                        </div>
                        <h3 className="text-base sm:text-lg font-semibold">Selected Plan</h3>
                      </div>
                      
                      <div className={`rounded-lg border-2 ${plan === "12 Months" ? "border-primary shadow-md" : "border-primary/20"} p-4 transition-all hover:shadow-md bg-white/50 backdrop-blur-sm`}>
                        <div className="flex justify-between items-center">
                          <div>
                            <h4 className="font-bold text-foreground">{plan}</h4>
                            <p className="text-sm text-muted-foreground">
                              {plan === "1 Month" && "Basic plan - $12 per month"}
                              {plan === "6 Months" && "Standard plan - $35 (Save $37 compared to monthly)"}
                              {plan === "12 Months" && "Premium plan - $69 (Only $5.75/month - Best Value!)"}
                            </p>
                          </div>
                          {plan === "12 Months" && (
                            <div className="bg-yellow-400 text-black text-xs font-bold px-2 py-1 rounded-full transform rotate-3 shadow-sm">BEST VALUE!</div>
                          )}
                        </div>
                        {plan === "12 Months" && (
                          <div className="bg-yellow-100 p-3 rounded-lg mt-3 text-sm text-yellow-800 flex items-start">
                            <CheckCircle className="h-5 w-5 text-yellow-600 mr-2 flex-shrink-0 mt-0.5" />
                            <span>You've selected our recommended plan with the best value! Includes premium support and priority service.</span>
                          </div>
                        )}
                      </div>
                      
                      <div className="mt-4 flex items-center gap-2 text-xs text-muted-foreground bg-white/30 p-2 rounded-lg">
                        <Shield className="h-4 w-4 text-primary/70" />
                        <span>Your payment information is encrypted and secure</span>
                      </div>
                    </div>
                  </div>
                </div>
                
                {formState.error && (
                  <Alert variant="destructive" className="mt-6">
                    <AlertDescription>{formState.error}</AlertDescription>
                  </Alert>
                )}
                
                <div className="flex justify-center pt-6">
                  <Button
                    type="submit"
                    className="w-full md:w-auto bg-primary hover:bg-primary/90 text-white font-semibold px-8 py-4 sm:py-5 rounded-lg text-base sm:text-lg shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-[1.02] disabled:hover:scale-100"
                    disabled={submitting}
                  >
                    {submitting ? (
                      <div className="flex items-center gap-2">
                        <svg className="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                          <circle className="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" strokeWidth="4"></circle>
                          <path className="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        Submitting...
                      </div>
                    ) : (
                      <div className="flex items-center gap-2">
                        Complete Subscription
                        <MoveRight className="h-5 w-5" />
                      </div>
                    )}
                  </Button>
                </div>
              </form>
            ) : (
              <div className="flex flex-col items-center justify-center py-12 space-y-8">
                <div className="w-24 h-24 bg-gradient-to-br from-green-100 to-green-200 rounded-full flex items-center justify-center shadow-md">
                  <CheckCircle className="h-12 w-12 text-green-600" />
                </div>
                <h3 className="text-2xl sm:text-3xl font-bold text-center bg-clip-text text-transparent bg-gradient-to-r from-primary to-primary/80">
                  Subscription Successful!
                </h3>
                <div className="bg-blue-50 p-4 rounded-xl border border-blue-200 max-w-md shadow-sm">
                  <div className="flex gap-3">
                    <div className="bg-blue-100 p-2 rounded-full h-fit">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className="h-5 w-5 text-blue-600">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                      </svg>
                    </div>
                    <div>
                      <h4 className="font-semibold text-blue-800 mb-1">Live Support Available</h4>
                      <p className="text-sm text-blue-700">
                        Our live chat support is now available to assist you with any questions. A chat window has been opened for you with an automatic message sent on your behalf.
                      </p>
                      <button 
                        onClick={() => {
                          setIsChatLoading(true);
                          
                          // Use our global function that has retry logic built in
                          if (typeof window !== 'undefined' && typeof window.openTawkChat === 'function') {
                            try {
                              window.openTawkChat();
                              // Set loading to false after a delay regardless of success
                              setTimeout(() => setIsChatLoading(false), 2000);
                            } catch (error) {
                              console.error('Error calling openTawkChat:', error);
                              setIsChatLoading(false);
                            }
                          } else {
                            // Fallback for older browsers or if our function isn't available
                            try {
                              // Try direct access first
                              if (window?.Tawk_API && typeof window.Tawk_API.maximize === 'function') {
                                window.Tawk_API.maximize();
                                setTimeout(() => setIsChatLoading(false), 1000);
                              } else {
                                // Alert the user if all methods fail
                                setTimeout(() => {
                                  setIsChatLoading(false);
                                  alert('Live chat is currently unavailable. Please refresh the page or contact support via email.');
                                }, 1000);
                              }
                            } catch (error) {
                              console.error('Error opening chat:', error);
                              setIsChatLoading(false);
                              alert('Could not open live chat. Please refresh the page or contact support via email.');
                            }
                          }
                        }}
                        disabled={isChatLoading}
                        className="mt-3 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md transition-colors flex items-center gap-2 shadow-sm"
                      >
                        {isChatLoading ? (
                          <>
                            <svg className="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                              <circle className="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" strokeWidth="4"></circle>
                              <path className="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            Opening Chat...
                          </>
                        ) : (
                          <>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
                              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                            </svg>
                            Open Chat Support
                          </>
                        )}
                      </button>
                    </div>
                  </div>
                </div>
                
                <Button 
                  onClick={goBack} 
                  className="mt-6 bg-primary hover:bg-primary/90 text-white shadow-lg hover:shadow-xl transition-all duration-300 px-8 py-4 text-base sm:text-lg rounded-lg flex items-center gap-2"
                >
                  <ChevronLeft className="h-4 w-4" />
                  Return to Homepage
                </Button>
              </div>
            )}
          </CardContent>
        </Card>
      </div>
      {/* Include the TawkToChat component with autoOpen based on success state */}
      <TawkToChat 
        autoOpen={isChatLoading || formState.success} 
        visitorInfo={{
          name: formState.name || '',
          email: formState.email || ''
        }}
        autoMessage={formState.name ? 
          `Hi, I'm ${formState.name}. I just subscribed to the ${plan} plan. Could you please help me get started?` : 
          `Hi, I just subscribed to the ${plan} plan. Could you please help me get started?`}
      />
    </div>
  );
}

// Wrapper component that includes Suspense boundary
export default function SubscribePage() {
  return (
    <Suspense fallback={
      <div className="min-h-screen bg-gradient-to-b from-background to-secondary/10 flex items-center justify-center">
        <div className="text-center p-6">
          <div className="w-16 h-16 mx-auto mb-4">
            <svg className="animate-spin h-full w-full text-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle className="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" strokeWidth="4"></circle>
              <path className="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </div>
          <p className="text-lg text-muted-foreground">Loading subscription page...</p>
        </div>
      </div>
    }>
      <SubscribePageContent />
    </Suspense>
  );
}